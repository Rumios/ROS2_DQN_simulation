<?xml version="1.0"?>
<robot name="dqn_4wheel_car">

  <!-- ========================================== -->
  <!-- 0. 글로벌 색상(Material) 정의             -->
  <!-- ========================================== -->
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.4 1.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- ========================================== -->
  <!-- 1. 지면 기준점 (base_footprint)            -->
  <!-- ========================================== -->
  <link name="base_footprint"/>

  <!-- ========================================== -->
  <!-- 2. 자동차 차체 (base_link)                  -->
  <!-- ========================================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.45 0.20 0.10"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ========================================== -->
  <!-- 3. 왼쪽 앞바퀴 (front_left_wheel)          -->
  <!-- ========================================== -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.15 0.12 -0.02" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 왼쪽 앞바퀴 회전 표시 선 -->
  <link name="front_left_wheel_stripe">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.11 0.01 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="front_left_wheel_stripe_joint" type="fixed">
    <parent link="front_left_wheel"/>
    <child link="front_left_wheel_stripe"/>
    <origin xyz="0 0 0.021" rpy="0 0 0"/>
  </joint>

  <!-- ========================================== -->
  <!-- 4. 오른쪽 앞바퀴 (front_right_wheel)        -->
  <!-- ========================================== -->
  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.15 -0.12 -0.02" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 오른쪽 앞바퀴 회전 표시 선 -->
  <link name="front_right_wheel_stripe">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.11 0.01 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="front_right_wheel_stripe_joint" type="fixed">
    <parent link="front_right_wheel"/>
    <child link="front_right_wheel_stripe"/>
    <origin xyz="0 0 0.021" rpy="0 0 0"/>
  </joint>

  <!-- ========================================== -->
  <!-- 5. 왼쪽 뒷바퀴 (rear_left_wheel)           -->
  <!-- ========================================== -->
  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.15 0.12 -0.02" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 왼쪽 뒷바퀴 회전 표시 선 -->
  <link name="rear_left_wheel_stripe">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.11 0.01 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="rear_left_wheel_stripe_joint" type="fixed">
    <parent link="rear_left_wheel"/>
    <child link="rear_left_wheel_stripe"/>
    <origin xyz="0 0 0.021" rpy="0 0 0"/>
  </joint>

  <!-- ========================================== -->
  <!-- 6. 오른쪽 뒷바퀴 (rear_right_wheel)         -->
  <!-- ========================================== -->
  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.15 -0.12 -0.02" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 오른쪽 뒷바퀴 회전 표시 선 -->
  <link name="rear_right_wheel_stripe">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.11 0.01 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="rear_right_wheel_stripe_joint" type="fixed">
    <parent link="rear_right_wheel"/>
    <child link="rear_right_wheel_stripe"/>
    <origin xyz="0 0 0.021" rpy="0 0 0"/>
  </joint>

  <!-- ========================================== -->
  <!-- 7. 지붕 위 라이다 센서 (lidar_link)          -->
  <!-- ========================================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.075" rpy="0 0 0"/>
  </joint>

</robot>